rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all to prevent unmapped access
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeacher() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // Users collection rules
    match /users/{userId} {
      // Allow any signed-in user to read user profiles (needed for teachers to view student profiles and vice versa)
      allow read: if isSignedIn();
      
      // Users can only create their own profile document
      allow create: if isSignedIn() && isOwner(userId);
      
      // Users can update their own profile (but cannot modify their role to escalate privileges),
      // or a teacher can update a student profile (needed for assigning to circles or class types)
      allow update: if isSignedIn() && (
        (isOwner(userId) && (request.resource.data.role == resource.data.role)) ||
        isTeacher()
      );
    }

    // Circles collection rules
    match /circles/{circleId} {
      // Allow signed-in users (teachers and students) to read circles
      allow read: if isSignedIn();
      
      // Only teachers can create circles, and they must assign themselves as the teacher of that circle
      allow create: if isSignedIn() && isTeacher() && request.resource.data.teacherId == request.auth.uid;
      
      // Only the teacher who owns the circle can update or delete it
      allow update, delete: if isSignedIn() && isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    // Assignments collection rules
    match /assignments/{assignmentId} {
      // Allow signed-in users (teachers and students) to read assignments
      allow read: if isSignedIn();
      
      // Only teachers can create assignments and they must be the owner
      allow create: if isSignedIn() && isTeacher() && request.resource.data.teacherId == request.auth.uid;
      
      // Only the teacher who owns the assignment can update or delete it,
      // EXCEPT students can submit/update the status of their own assignment to 'review' when they submit
      allow update: if isSignedIn() && (
        (isTeacher() && resource.data.teacherId == request.auth.uid) ||
        (request.auth.uid == resource.data.studentId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
      );

      allow delete: if isSignedIn() && isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    // Submissions collection rules
    match /submissions/{submissionId} {
      // Allow signed-in users (teachers and the student who owns the submission) to read submissions
      allow read: if isSignedIn() && (
        isTeacher() || 
        resource.data.studentId == request.auth.uid
      );
      
      // Students and teachers can create submissions
      allow create: if isSignedIn() && (
        isTeacher() || 
        request.resource.data.studentId == request.auth.uid
      );

      // Teachers can update submissions (for grading/feedback),
      // and students can update their own submission but are strictly forbidden from modifying grading/feedback fields
      allow update: if isSignedIn() && (
        isTeacher() || 
        (resource.data.studentId == request.auth.uid && 
         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['score', 'feedback', 'gradedAt', 'reviewStatus'])))
      );

      allow delete: if isSignedIn() && isTeacher();
    }

    // Questions collection rules
    match /questions/{questionId} {
      // Allow any signed-in users (teachers and students) to read questions
      allow read: if isSignedIn();

      // Only teachers can create, update, or delete questions
      allow create, update, delete: if isSignedIn() && isTeacher();
    }

    // Modules collection rules
    match /modules/{moduleId} {
      // Allow signed-in users to read modules
      allow read: if isSignedIn();

      // Only teachers can write/modify modules
      allow write: if isSignedIn() && isTeacher();
    }

    // Module Access Keys collection rules
    match /module_access_keys/{keyId} {
      // Allow signed-in users to read keys (e.g. for claiming vouchers)
      allow read: if isSignedIn();

      // Teachers can create and delete keys
      allow create, delete: if isSignedIn() && isTeacher();

      // Students/Teachers can update keys (e.g. to increment usageCount)
      allow update: if isSignedIn();
    }

    // System config collection rules
    match /system/{document} {
      allow read: if true;
      allow write: if isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'fatih@kavio.tec.edu'
      );
    }

    // Package Registrations collection rules
    match /package_registrations/{registrationId} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // Schedules collection rules
    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
